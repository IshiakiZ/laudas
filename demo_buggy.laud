; Demo: a deliberately broken safe_div.
; Run:   python laudas.py demo_buggy.laud
;
; The bug: returns Some(0) on division-by-zero instead of None.
; Three examples are declared. Two pass, one fails.
; The verification feedback loop demos itself: example failure
; produces a structured LLM-shaped diagnostic with ranked fixes.

fn safe_div
vis appearing
eff pure
in a: int
in b: int
out int?
ex safe_div(10, 2) == Some(5)
ex safe_div(7, 2) == Some(3)
ex safe_div(7, 0) == None
ens result.is_some() iff b != 0
do
if b == 0 { return Some(0) }
return Some(a / b)
end
