; ============================================================
; Laudas — wire format examples
; Volume I, illustrative entries
; ============================================================
;
; Comments use ;
; Slot order is fixed: fn, vis, for?, eff, in*, out, ex*, req*, ens*, prose?, do, body, end
; All keywords are single-token in cl100k / o200k.
; No indentation on slot lines (single-space indent would merge fine, but flat is canonical).


; --- 1. Pure function with refinement on output -------------

fn safe_div
vis appearing
eff pure
in a: int
in b: int
out int?
ex safe_div(10, 2) == Some(5)
ex safe_div(7, 2) == Some(3)
ex safe_div(7, 0) == None
ens result.is_some() iff b != 0
do
if b == 0 { return None }
return Some(a / b)
end


; --- 2. Refinement types on inputs and output ---------------

fn percentage
vis appearing
eff pure
in part: int { >= 0 }
in whole: int { > 0 }
out int { 0..=100 }
ex percentage(25, 100) == 25
ex percentage(1, 3) == 33
ex percentage(0, 5) == 0
ens result <= 100
do
return (part * 100) / whole
end


; --- 3. Effects in action -----------------------------------

fn cached_fetch
vis appearing
eff io,cache
in url: Url
out Bytes
ex cached_fetch("https://laudas.dev/v1") -- first call hits network, second hits cache
do
if cache.has(url) { return cache.get(url) }
let bytes = http.get(url)
cache.put(url, bytes)
return bytes
end


; --- 4. Sunsetting via disappearing(version: X) -------------

fn legacy_path
vis disappearing(version: 2.0)
eff pure
in input: str
out str
ex legacy_path("hello") == "HELLO"
prose "Old uppercase pipeline. Replaced by stdlib.text.upper in v1.5; sunset target v2.0."
do
return input.upper()
end


; --- 5. Trait implementation via `for` ----------------------
; `for` in wire renders as "answering Display" in display format.

fn render
vis appearing
for Display
eff pure
in u: User
out Html
ex render(User { name: "Mira", role: "engineer" }) == "<div>Mira (engineer)</div>"
do
return "<div>" + u.name + " (" + u.role + ")</div>"
end


; --- 6. Spec-first inversion: empty body ---------------------
; mira request-body fills the do-block; voronin verifies the result.

fn isort
vis appearing
eff pure
in xs: list<int>
out list<int>
ex isort([3, 1, 2]) == [1, 2, 3]
ex isort([]) == []
ex isort([5]) == [5]
ens result.length == xs.length
ens result.is_sorted_ascending()
do
end


; --- 7. Effect-leak example (intentionally broken) ----------
; This demonstrates the LLM-shaped error format. The function
; below claims `eff pure` but calls `cached_fetch`, which has
; `eff io,cache`. Voronin emits:
;
;   {
;     "error": "effect-leak",
;     "location": "examples.laud:97",
;     "function": "summarize",
;     "expected": "eff pure",
;     "found":    "calls cached_fetch with eff io,cache",
;     "suggestions": [
;       {"rank": 1, "fix": "change summarize to `eff io,cache`"},
;       {"rank": 2, "fix": "accept bytes as a parameter, fetch outside"},
;       {"rank": 3, "fix": "memoize cached_fetch result outside summarize"}
;     ],
;     "explanation": "summarize is declared pure but transitively calls IO. ..."
;   }

fn summarize
vis appearing
eff pure
in url: Url
out str
ex summarize("https://laudas.dev/v1") == "..."
do
let bytes = cached_fetch(url)
return text.summarize(bytes)
end
