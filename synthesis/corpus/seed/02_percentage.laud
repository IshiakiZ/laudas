; corpus seed — bounded percentage with refinement-typed inputs

fn percentage
vis appearing
eff pure
in part: int
in whole: int
req part >= 0
req whole > 0
req part <= whole
out int
ex percentage(25, 100) == 25
ex percentage(1, 3) == 33
ex percentage(0, 5) == 0
ens result >= 0
ens result <= 100
do
let scaled = part * 100
return scaled / whole
end
